{
  "schema_version": "1.0.0",
  "rules": [
    {
      "id": "T-DROPPER",
      "title": "Dropper packages with and without notes",
      "kind": "compromised-release",
      "ecosystem": "npm",
      "severity": "critical",
      "package_rules": [{ "package_name": "main-pkg", "affected_versions": ["1.0.0"] }],
      "dropper_packages": [
        { "package_name": "dropper-with-notes", "notes": "Installed via postinstall script." },
        { "package_name": "dropper-no-notes" }
      ]
    }
  ]
}
