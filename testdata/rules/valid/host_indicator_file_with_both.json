{
  "schema_version": "1.0.0",
  "rules": [
    {
      "id": "T-HI-FILE-BOTH",
      "title": "File indicator with both path and file_name",
      "kind": "compromised-release",
      "ecosystem": "npm",
      "severity": "critical",
      "package_rules": [{ "package_name": "pkg", "affected_versions": ["1.0.0"] }],
      "host_indicators": [
        {
          "type": "file",
          "path": "/tmp",
          "file_name": "malware.bin",
          "oses": ["windows"]
        }
      ]
    }
  ]
}
